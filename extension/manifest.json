{
  "manifest_version": 3,
  "name": "Tambourine — Growth Signals",
  "short_name": "Tambourine",
  "version": "1.0.0",
  "description": "Find your fastest-growing TAM. Account-level growth signals on every site you visit.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tambourine — Growth Signals",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "options_page": "options.html"
}
